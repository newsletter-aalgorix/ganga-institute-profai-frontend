# ============================================
# FIREBASE AUTHENTICATION CONFIGURATION
# ============================================
# 
# Instructions:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project or select existing one
# 3. Go to Project Settings > General > Your apps
# 4. Copy the configuration values below
# 5. Rename this file to .env and fill in your values
#
# IMPORTANT: Never commit the actual .env file to git!
# ============================================

# Firebase API Key (Public - safe to expose in client)
VITE_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase App ID
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Firebase Measurement ID (Optional - for Analytics)
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# EXISTING ENVIRONMENT VARIABLES
# ============================================
# Keep your existing environment variables below
# (DATABASE_URL, SESSION_SECRET, etc.)
