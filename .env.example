# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/profaicoach

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
SESSION_NAME=sid

# Server Configuration
PORT=5000
NODE_ENV=development

# Cookie Configuration
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth Redirect URLs
REDIRECT_URL=http://localhost:5000/auth/callback
TEACHER_REDIRECT_URL=http://localhost:3000/teacher/dashboard
STUDENT_REDIRECT_URL=http://localhost:3000/student/dashboard

# Client-side Variables (VITE_ prefixed)
# For local development:
VITE_API_BASE=http://localhost:5000
VITE_API_URL=ws://localhost:5000
VITE_AVI_URL=http://localhost:8080
VITE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# For production with EC2 backend (Docker):
# VITE_API_BASE=http://YOUR_EC2_IP:5001
# VITE_API_URL=ws://YOUR_EC2_IP:5001
# VITE_AVI_URL=http://YOUR_EC2_IP:3002
# VITE_AUTH_REDIRECT_URL=https://yourdomain.com/auth/callback
