{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/index.ts",
    "start": "cross-env NODE_ENV=production PORT=5004 node dist/index.js",
    "build-client": "vite build",
    "build-client:prod": "vite build --mode production",
    "build-server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "predeploy": "npm run build-client",
    "deploy": "gh-pages -d dist",
    "build": "npm run build-client && npm run build-server",
    "build:prod": "npm run build-client:prod && npm run build-server",
    "preview": "vite preview",
    "check": "tsc",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "drizzle-kit up:pg",
    "db:check": "drizzle-kit check:pg",
    "setup-pricing": "tsx scripts/setup-course-pricing.ts",
    "setup-pricing:help": "tsx scripts/setup-course-pricing.ts --help",
    "setup-pricing:direct": "tsx scripts/direct-setup.ts",
    "set-all-free": "tsx scripts/set-all-courses-free.ts",
    "setup:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-production.ps1",
    "fetch-course-ids": "tsx scripts/fetch-and-generate-mappings.ts",
    "migrate-course-ids": "tsx scripts/migrate-course-ids.ts",
    "view-course-mappings": "tsx scripts/view-course-mappings.ts",
    "sync-course-names": "tsx scripts/sync-course-names.ts",
    "view-course-images": "tsx scripts/view-course-images.ts",
    "backup-db": "tsx scripts/backup-database.ts"
  },
  "dependencies": {
